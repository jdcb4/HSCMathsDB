{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goalcheck.local/schemas/other-project-output.schema.json",
  "title": "GoalCheck HSC Other Project Parser Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "generator", "sourcePacks", "papers", "questions"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },
    "sourcePacks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourcePack" }
    },
    "papers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/paper" }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/question" }
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/externalAssetFile" },
      "default": []
    },
    "validationNotes": {
      "type": "array",
      "items": { "$ref": "#/$defs/validationNote" },
      "default": []
    }
  },
  "$defs": {
    "courseId": {
      "type": "string",
      "enum": ["advanced", "standard", "extension-1", "extension-2", "mathematics-archive"]
    },
    "syllabusEra": {
      "type": "string",
      "enum": [
        "advanced-2017",
        "advanced-2024",
        "standard-2017",
        "standard-2024",
        "extension-1-2017",
        "extension-1-2024",
        "extension-2-2017",
        "extension-2-2024",
        "mathematics-2-unit-archive"
      ]
    },
    "url": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "sourceAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "label", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "role": {
          "type": "string",
          "enum": ["exam-paper", "marking-guide", "marking-feedback", "standards-material", "syllabus"]
        },
        "label": { "type": "string", "minLength": 1 },
        "url": { "$ref": "#/$defs/url" },
        "status": {
          "type": "string",
          "enum": ["linked", "pending", "not-applicable"]
        },
        "localPath": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
      }
    },
    "sourcePack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "courseId",
        "collectionId",
        "year",
        "courseName",
        "title",
        "packPageUrl",
        "syllabusEra",
        "officialListStatus",
        "importStatus",
        "importedQuestionCount",
        "assetStatus",
        "assets"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "courseId": { "$ref": "#/$defs/courseId" },
        "paperId": { "type": "string", "minLength": 1 },
        "paperIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "collectionId": { "type": "string", "minLength": 1 },
        "year": { "type": "integer", "minimum": 1900, "maximum": 2100 },
        "courseName": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "packPageUrl": { "$ref": "#/$defs/url" },
        "syllabusEra": { "$ref": "#/$defs/syllabusEra" },
        "officialListStatus": {
          "type": "string",
          "enum": ["listed", "expected", "retired"]
        },
        "importStatus": {
          "type": "string",
          "enum": ["not-started", "seeded", "in-progress", "verified"]
        },
        "expectedQuestionCount": { "type": "integer", "minimum": 1 },
        "importedQuestionCount": { "type": "integer", "minimum": 0 },
        "assetStatus": {
          "type": "string",
          "enum": ["none-identified", "pending-extraction", "partial", "complete"]
        },
        "notes": { "type": "string", "minLength": 1 },
        "assets": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceAsset" },
          "default": []
        }
      },
      "oneOf": [
        { "required": ["paperId"], "not": { "required": ["paperIds"] } },
        { "required": ["paperIds"], "not": { "required": ["paperId"] } }
      ]
    },
    "paper": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sourcePackId",
        "courseId",
        "year",
        "courseName",
        "syllabusEra",
        "examPackUrl",
        "sourceStatus",
        "sections"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sourcePackId": { "type": "string", "minLength": 1 },
        "courseId": { "$ref": "#/$defs/courseId" },
        "year": { "type": "integer", "minimum": 1900, "maximum": 2100 },
        "courseName": { "type": "string", "minLength": 1 },
        "syllabusEra": { "$ref": "#/$defs/syllabusEra" },
        "examPackUrl": { "$ref": "#/$defs/url" },
        "paperUrl": { "$ref": "#/$defs/url" },
        "markingGuideUrl": { "$ref": "#/$defs/url" },
        "sourceStatus": {
          "type": "string",
          "enum": ["source-linked", "partially-transcribed", "complete"]
        },
        "expectedQuestionCount": { "type": "integer", "minimum": 1 },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/paperSection" }
        }
      }
    },
    "paperSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "questionNumbers"],
      "properties": {
        "id": { "type": "string", "enum": ["I", "II"] },
        "title": { "type": "string", "minLength": 1 },
        "style": {
          "type": "string",
          "enum": ["multiple-choice", "written-response", "mixed"]
        },
        "questionNumbers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "pageRefs": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "default": []
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "paperId",
        "year",
        "questionNumber",
        "section",
        "title",
        "marks",
        "style",
        "topic",
        "subtopic",
        "syllabusNodeIds",
        "promptLatex",
        "answerLatex",
        "workingLatex",
        "tags",
        "assets",
        "source",
        "review"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "paperId": { "type": "string", "minLength": 1 },
        "year": { "type": "integer", "minimum": 1900, "maximum": 2100 },
        "questionNumber": { "type": "string", "pattern": "^Q?[0-9]+[a-zA-Z]?$" },
        "section": { "type": "string", "enum": ["I", "II"] },
        "title": { "type": "string", "minLength": 1 },
        "marks": { "type": "integer", "minimum": 1 },
        "style": {
          "type": "string",
          "enum": ["multiple-choice", "short-answer", "extended-response", "proof", "modelling"]
        },
        "topic": { "type": "string", "minLength": 1 },
        "subtopic": { "type": "string", "minLength": 1 },
        "syllabusNodeIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "syllabusMappingEvidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/syllabusMappingEvidence" },
          "default": []
        },
        "promptLatex": { "type": "string", "minLength": 1 },
        "answerLatex": { "type": "string", "minLength": 1 },
        "workingLatex": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "markingFeedback": { "$ref": "#/$defs/markingFeedback" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "assets": {
          "type": "array",
          "items": { "$ref": "#/$defs/questionAsset" },
          "default": []
        },
        "source": { "$ref": "#/$defs/questionSource" },
        "review": { "$ref": "#/$defs/questionReview" },
        "rawExtraction": { "$ref": "#/$defs/rawExtraction" }
      }
    },
    "syllabusMappingEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["syllabusNodeId", "source", "confidence", "basis"],
      "properties": {
        "syllabusNodeId": { "type": "string", "minLength": 1 },
        "source": {
          "type": "string",
          "enum": ["marking-grid", "prompt", "marking-guide", "manual-review", "parser-inference"]
        },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "basis": { "type": "string", "minLength": 1 },
        "mapped2024NodeIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "markingFeedback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceRef", "betterResponses", "improvementAreas"],
      "properties": {
        "sourceRef": { "type": "string", "minLength": 1 },
        "betterResponses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "improvementAreas": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    },
    "questionAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "label", "alt", "path", "sourceStatus"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["diagram", "graph", "table", "image"] },
        "label": { "type": "string", "minLength": 1 },
        "alt": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "pattern": "^/assets/diagrams/.+\\.(png|jpg|jpeg|webp|svg)$" },
        "sourceStatus": { "type": "string", "enum": ["exam-derived", "demo", "pending"] },
        "sourcePage": { "type": "integer", "minimum": 1 },
        "crop": { "$ref": "#/$defs/crop" },
        "reviewStatus": { "type": "string", "enum": ["needs-review", "reviewed", "rejected"] }
      }
    },
    "crop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number", "minimum": 0 },
        "y": { "type": "number", "minimum": 0 },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "units": { "type": "string", "enum": ["px", "pdf-points"], "default": "px" }
      }
    },
    "questionSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["examPackUrl", "transcriptionStatus"],
      "properties": {
        "examPackUrl": { "$ref": "#/$defs/url" },
        "pageRef": { "type": "string", "minLength": 1 },
        "markingGuideRef": { "type": "string", "minLength": 1 },
        "transcriptionStatus": { "type": "string", "enum": ["demo", "draft", "verified"] }
      }
    },
    "questionReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "issues"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["needs-review", "parser-reviewed", "source-reviewed", "rejected"]
        },
        "issues": {
          "type": "array",
          "items": { "$ref": "#/$defs/validationNote" },
          "default": []
        },
        "reviewedBy": { "type": "string", "minLength": 1 },
        "reviewedAt": { "type": "string", "format": "date-time" }
      }
    },
    "rawExtraction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "promptText": { "type": "string" },
        "answerText": { "type": "string" },
        "pageNumbers": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "default": []
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      }
    },
    "externalAssetFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["generated", "reviewed", "pending"] },
        "sourceQuestionId": { "type": "string", "minLength": 1 },
        "sourcePage": { "type": "integer", "minimum": 1 },
        "crop": { "$ref": "#/$defs/crop" }
      }
    },
    "validationNote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "message"],
      "properties": {
        "severity": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    }
  }
}
